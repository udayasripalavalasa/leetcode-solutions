class Solution(object):
    def longestCommonPrefix(self, strs):
        if not strs:
            return ""

        s = strs[0]
        ans = []

        for i in range(len(s)):
            for j in range(1, len(strs)):
                if i >= len(strs[j]) or s[i] != strs[j][i]:
                    return "".join(ans)
            ans.append(s[i])

        return "".join(ans)